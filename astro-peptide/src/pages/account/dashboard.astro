---
import Layout from '../../layouts/Layout.astro';
import AccountDashboard from '../../components/Dashboard';
import Breadcrumb from '../../components/Breadcrumb.astro';
import PageHeading from '../../components/PageHeading.astro';
import { getLocaleFromPathname, localizePath } from '../../i18n/config';
import { useTranslations } from '../../i18n/ui';

const locale = (Astro.locals.locale ?? getLocaleFromPathname(Astro.url.pathname));
const t = useTranslations(locale);
const href = (path: string) => localizePath(path, locale);
const dashboardLabelKeys = [
  'overview', 'orders', 'addresses', 'settings', 'redirecting', 'redirectBody', 'accountSections', 'signOut',
  'accountOverview', 'welcomeBack', 'welcomeBody', 'accountSummary', 'totalSpend', 'defaultDeliveryAddress',
  'noDefaultAddress', 'total', 'noOrdersTitle', 'noOrdersBody', 'browseCatalogue', 'order', 'date', 'status',
  'payment', 'saved', 'noAddresses', 'default', 'profileSettings', 'editProfile', 'firstName', 'lastName',
  'phone', 'saveChanges', 'cancel', 'name', 'email', 'notProvided', 'provider',
] as const;
const dashboardLabels = Object.fromEntries(dashboardLabelKeys.map((key) => [key, t(`accountDashboard.${key}`)]));
---

<Layout title={t('accountPage.metaTitle')} description={t('accountPage.metaDescription')} noindex={true}>
  <section class="commerce-page section">
    <div class="container">
      <Breadcrumb items={[{ name: t('common.home'), url: href('/') }, { name: t('account.account') }]} />

      <PageHeading
        eyebrow={t('account.account')}
        title={t('account.dashboard')}
        description={t('accountPage.description')}
      />

      <AccountDashboard labels={dashboardLabels} paths={{ checkout: href('/checkout/'), home: href('/'), shop: href('/shop/') }} client:only="react" />
    </div>
  </section>
</Layout>
