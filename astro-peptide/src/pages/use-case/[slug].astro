---
import Layout from '../../layouts/Layout.astro';
import JsonLd from '../../components/JsonLd.astro';
import ProductCard from '../../components/ProductCard.astro';
import { toCardProduct } from '../../lib/product';
import Breadcrumb from '../../components/Breadcrumb.astro';
import RUOBanner from '../../components/RUOBanner.astro';
import { useCases, getUseCase, type UseCaseSlug } from '../../data/taxonomy';
import { getCanonicalCollection } from '../../lib/collections';
import { getLocaleFromPathname, localizePath } from '../../i18n/config';
import { useTranslations } from '../../i18n/ui';
import { getLocalizedProduct } from '../../i18n/productContent';

export const prerender = false;

const { slug } = Astro.params;
const meta = getUseCase(slug as string);
const locale = (Astro.locals.locale ?? getLocaleFromPathname(Astro.url.pathname));
const t = useTranslations(locale);
const href = (path: string) => localizePath(path, locale);

if (!meta) {
  return Astro.redirect(href('/catalog/'), 302);
}

const useCaseName = t(`taxonomy.useCases.${meta.slug}.name`);
const useCaseDescription = t(`taxonomy.useCases.${meta.slug}.description`);
const useCaseSlug = slug as UseCaseSlug;

const all = await getCanonicalCollection('products');
const products = all
  .filter((p) => Array.isArray(p.data.useCases) && p.data.useCases.includes(useCaseSlug))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const url = new URL(Astro.url.pathname, Astro.site).toString();

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  numberOfItems: products.length,
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: new URL(href(`/peptides/${p.slug}/`), Astro.site).toString(),
    name: getLocalizedProduct(p, locale).title,
  })),
};

const collectionPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: useCaseName,
  description: useCaseDescription,
  url,
  inLanguage: locale,
};

const breadcrumbs = [
  { name: t('common.home'), url: href('/') },
  { name: t('nav.catalogue'), url: href('/catalog/') },
  { name: useCaseName, url: href(`/use-case/${meta.slug}/`) },
];
---

<Layout
  title={t('useCasePage.metaTitle', { useCase: useCaseName })}
  description={t('useCasePage.metaDescription', { description: useCaseDescription })}
  breadcrumbs={breadcrumbs}
>
  <JsonLd schema={[collectionPageSchema, itemListSchema]} />

  <section class="section">
    <div class="container">
      <Breadcrumb items={breadcrumbs} />

      <span class="eyebrow">{t('shopSidebar.useCase')}</span>
      <h1>{useCaseName}</h1>
      <p class="lead">{useCaseDescription}</p>

      <RUOBanner
        style="margin-top: var(--space-6);"
        heading={t('productPage.ruoHeading')}
        detail={t('useCasePage.ruoDetail')}
      />

      {products.length === 0 ? (
        <p style="margin-top: var(--space-8); color: var(--color-ink-3);">{t('useCasePage.noProducts')}</p>
      ) : (
        <div class="grid grid-3" style="margin-top: var(--space-10);">
          {products.map((p) => (
            <ProductCard product={toCardProduct(p, locale)} />
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
