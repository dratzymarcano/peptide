---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import JsonLd from '../../components/JsonLd.astro';
import { getLocaleFromPathname, localizePath } from '../../i18n/config';
import { useTranslations } from '../../i18n/ui';

export const prerender = false;

const locale = (Astro.locals.locale ?? getLocaleFromPathname(Astro.url.pathname));
const t = useTranslations(locale);
const href = (path: string) => localizePath(path, locale);

const learnEntries = (await getCollection('learn'))
  .sort((a, b) => (a.data.order || 999) - (b.data.order || 999));

const guides = [
  {
    title: t('learn.guides.peptides.title'),
    description: t('learn.guides.peptides.description'),
    href: href('/learn/what-are-peptides/'),
    readTime: t('learn.readTimeEight'),
    category: t('learn.eyebrow'),
  },
  ...learnEntries.map((entry) => ({
    title: entry.data.title,
    description: entry.data.description,
    href: href(`/learn/${entry.id}/`),
    readTime: entry.data.readTime,
    category: entry.data.category,
  })),
];

const breadcrumbs = [
  { name: t('common.home'), url: href('/') },
  { name: t('learn.breadcrumb'), url: href('/learn/') },
];

const learningSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: t('learn.schemaName'),
  description: t('learn.schemaDescription'),
  url: new URL(href('/learn/'), Astro.site).toString(),
  inLanguage: locale,
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: guides.map((guide, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: guide.title,
      url: new URL(guide.href, Astro.site).toString(),
    })),
  },
};
---

<Layout
  title={t('learn.metaTitle')}
  description={t('learn.metaDescription')}
  breadcrumbs={breadcrumbs}
>
  <JsonLd schema={learningSchema} />

  <section class="content-page section">
    <div class="container">
      <Breadcrumb items={breadcrumbs} />

      <div class="page-heading">
        <span class="eyebrow">{t('learn.eyebrow')}</span>
        <h1>{t('learn.title')}</h1>
        <p>{t('learn.description')}</p>
      </div>

      <div class="content-layout">
        <main class="article-grid" aria-label={t('learn.guidesLabel')}>
          {guides.map((guide) => (
            <a class="learning-card card" href={guide.href}>
              <span class="badge badge-blue">{t('learn.guideBadge', { readTime: guide.readTime })}</span>
              <h2>{guide.title}</h2>
              <p>{guide.description}</p>
              <span class="text-primary">{t('learn.readGuide')}</span>
            </a>
          ))}
        </main>

        <aside class="content-sidebar">
          <section class="card">
            <h2>{t('learn.relatedResources')}</h2>
            <a class="btn btn-secondary" href={href('/quality/')}>{t('learn.qualityStandards')}</a>
            <a class="btn btn-secondary" href={href('/coa-policy/')}>{t('support.coaPolicy')}</a>
            <a class="btn btn-secondary" href={href('/blog/')}>{t('blog.breadcrumb')}</a>
          </section>
          <section class="card">
            <h2>{t('nav.catalogue')}</h2>
            <p>{t('learn.catalogueBody')}</p>
            <a class="btn btn-primary" href={href('/catalog/')}>{t('learn.openCatalogue')}</a>
          </section>
        </aside>
      </div>
    </div>
  </section>
</Layout>
