---
import Layout from '../../layouts/Layout.astro';
import JsonLd from '../../components/JsonLd.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import RUOBanner from '../../components/RUOBanner.astro';
import ChipList from '../../components/ChipList.astro';
import { getLocaleFromPathname, localizePath } from '../../i18n/config';
import { useTranslations } from '../../i18n/ui';

export const prerender = false;

const locale = (Astro.locals.locale ?? getLocaleFromPathname(Astro.url.pathname));
const t = useTranslations(locale);
const href = (path: string) => localizePath(path, locale);

const peptideCategories = [
  { name: t('learnArticle.categories.glp1.name'), description: t('learnArticle.categories.glp1.description'), examples: ['Semaglutide', 'Tirzepatide', 'Retatrutide', 'Cagrilintide'] },
  { name: t('learnArticle.categories.gh.name'), description: t('learnArticle.categories.gh.description'), examples: ['Ipamorelin', 'GHRP-2', 'GHRP-6', 'CJC-1295'] },
  { name: t('learnArticle.categories.repair.name'), description: t('learnArticle.categories.repair.description'), examples: ['BPC-157', 'TB-500', 'GHK-Cu'] },
  { name: t('learnArticle.categories.neuro.name'), description: t('learnArticle.categories.neuro.description'), examples: ['Semax', 'Selank', 'DSIP', 'Epitalon'] },
];

const faqs = [
  { question: t('learnArticle.faqs.difference.question'), answer: t('learnArticle.faqs.difference.answer') },
  { question: t('learnArticle.faqs.synthesis.question'), answer: t('learnArticle.faqs.synthesis.answer') },
  { question: t('learnArticle.faqs.hplc.question'), answer: t('learnArticle.faqs.hplc.answer') },
  { question: t('learnArticle.faqs.pharma.question'), answer: t('learnArticle.faqs.pharma.answer') },
  { question: t('learnArticle.faqs.storage.question'), answer: t('learnArticle.faqs.storage.answer') },
];

const pageUrl = new URL(href('/learn/what-are-peptides/'), Astro.site).toString();
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: t('learnArticle.title'),
  description: t('learnArticle.metaDescription'),
  inLanguage: locale,
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
  author: { '@type': 'Organization', name: 'Peptide Shop' },
  publisher: { '@type': 'Organization', name: 'Peptide Shop', url: 'https://peptide-shop.net' },
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const breadcrumbs = [
  { name: t('common.home'), url: href('/') },
  { name: t('learn.breadcrumb'), url: href('/learn/') },
  { name: t('learnArticle.title'), url: href('/learn/what-are-peptides/') },
];
---

<Layout
  title={t('learnArticle.metaTitle')}
  description={t('learnArticle.metaDescription')}
  breadcrumbs={breadcrumbs}
>
  <JsonLd schema={[articleSchema, faqSchema]} />

  <article class="content-page article-page section">
    <div class="container">
      <Breadcrumb items={breadcrumbs} />

      <header class="article-header">
        <span class="badge badge-blue">{t('learn.guideBadge', { readTime: t('learn.readTimeEight') })}</span>
        <h1>{t('learnArticle.title')}</h1>
        <p>{t('learnArticle.lead')}</p>
      </header>

      <div class="content-layout">
        <main class="article-body card">
          <h2>{t('learnArticle.briefTitle')}</h2>
          <p>{t('learnArticle.briefBody1')}</p>
          <p>{t('learnArticle.briefBody2')}</p>

          <h2>{t('learnArticle.synthesisTitle')}</h2>
          <p>{t('learnArticle.synthesisBody')}</p>
          <RUOBanner
            variant="compact"
            heading={t('productPage.ruoHeading')}
            detail={t('learnArticle.ruoDetail')}
          />

          <h2>{t('learnArticle.categoriesTitle')}</h2>
          <div class="learning-grid">
            {peptideCategories.map((category) => (
              <section class="learning-panel">
                <h3>{category.name}</h3>
                <p>{category.description}</p>
                <ChipList items={category.examples} />
              </section>
            ))}
          </div>

          <h2>{t('learnArticle.purityTitle')}</h2>
          <p>{t('learnArticle.purityBody1')}</p>
          <p>{t('learnArticle.purityBody2')}</p>

          <h2>{t('support.faqTitle')}</h2>
          <div class="faq-list">
            {faqs.map((faq, index) => (
              <details class="faq-item" open={index === 0}>
                <summary>{faq.question}</summary>
                <p>{faq.answer}</p>
              </details>
            ))}
          </div>
        </main>

        <aside class="content-sidebar">
          <section class="card">
            <h2>{t('learnArticle.nextSteps')}</h2>
            <a class="btn btn-secondary" href={href('/blog/understanding-peptide-purity-hplc-reports/')}>{t('learnArticle.hplcReports')}</a>
            <a class="btn btn-secondary" href={href('/blog/peptide-storage-handling-best-practices/')}>{t('learnArticle.storageBestPractices')}</a>
            <a class="btn btn-primary" href={href('/catalog/')}>{t('catalogIndex.browseCatalogue')}</a>
          </section>
          <section class="card">
            <h2>{t('learnArticle.qualityDocumentation')}</h2>
            <p>{t('learnArticle.qualityDocumentationBody')}</p>
            <a class="btn btn-secondary" href={href('/coa-policy/')}>{t('learnArticle.viewCoaPolicy')}</a>
          </section>
        </aside>
      </div>
    </div>
  </article>
</Layout>
