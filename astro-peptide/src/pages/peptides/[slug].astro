---
import { getCanonicalCollection } from '../../lib/collections';
import { render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import JsonLd from '../../components/JsonLd.astro';
import ProductOptions from '../../components/ProductOptions';
import ProductCard from '../../components/ProductCard.astro';
import { toCardProduct } from '../../lib/product';
import ProductFAQs from '../../components/ProductFAQs.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import RUOBanner from '../../components/RUOBanner.astro';
import ShopSidebar from '../../components/ShopSidebar.astro';
import { getResearchArea, useCases, type UseCaseSlug } from '../../data/taxonomy';
import { getLocaleFromPathname, localizePath, localeMeta } from '../../i18n/config';
import { useTranslations } from '../../i18n/ui';
import { getLocalizedProduct } from '../../i18n/productContent';
import { getAvailableLocales, getLocalizedEntry } from '../../lib/localizedEntry';
import { inLanguage } from '../../lib/schema';
import { DEFAULT_LOCALE as DEFAULT_COA_LOCALE, SUPPORTED_LOCALES as SUPPORTED_COA_LOCALES } from '../../lib/coa/i18n';
import entities from '../../data/entities.json';

export const prerender = false;

const { slug: routeSlug } = Astro.params;
const allProductsForLookup = await getCanonicalCollection('products');
const product = allProductsForLookup.find((p) => p.id === routeSlug);
if (!product) {
  return new Response(null, { status: 404 });
}
const { Content } = await render(product);
const locale = (Astro.locals.locale ?? getLocaleFromPathname(Astro.url.pathname));
const t = useTranslations(locale);
const href = (path: string) => localizePath(path, locale);

const currentSlug = product.id;
const availableLocales = await getAvailableLocales('products', currentSlug);

// Per-locale markdown override. When a `<locale>/<slug>.md` exists under
// `src/content/products/`, prefer its frontmatter (title, meta, faqs,
// short_description, storage, price_range) and rendered body for non-English
// locales. Falls back to the runtime helper otherwise.
const localeOverride = locale !== 'en'
  ? await getLocalizedEntry('products', currentSlug, locale)
  : undefined;
const hasOverride = !!(localeOverride && localeOverride.id !== currentSlug);
const OverrideContent = hasOverride ? (await render(localeOverride!)).Content : null;

let localizedProduct = getLocalizedProduct(product, locale);
if (hasOverride && localeOverride) {
  const od = localeOverride.data;
  const cleanFromOverride = od.title.split(' — ')[0].split(' – ')[0].trim();
  localizedProduct = {
    ...localizedProduct,
    title: od.title,
    cleanTitle: cleanFromOverride,
    shortDescription: od.short_description,
    storage: od.storage,
    priceRange: od.price_range,
    meta: od.meta,
    faqs: od.faqs ?? [],
  };
}

const cleanTitle = localizedProduct.cleanTitle;
const productImage = product.data.images?.[0] ?? '/images/peptide-default.jpg';
const siteUrl = 'https://peptide-kaufen.net';
const productUrl = `${siteUrl}${href(`/peptides/${currentSlug}/`)}`;
const productImageUrl = productImage.startsWith('http') ? productImage : `${siteUrl}${productImage}`;
const researchArea = product.data.researchArea ? getResearchArea(product.data.researchArea) : undefined;
const researchAreaName = researchArea ? t(`taxonomy.researchAreas.${researchArea.slug}.name`) : undefined;
const productUseCases = (product.data.useCases ?? [])
  .map((useCaseSlug: string) => {
    const useCase = useCases.find((candidate) => candidate.slug === useCaseSlug);
    return useCase ? { slug: useCase.slug, name: t(`taxonomy.useCases.${useCase.slug}.name`) } : undefined;
  })
  .filter((useCase): useCase is { slug: UseCaseSlug; name: string } => Boolean(useCase));
const alternateCoaLocales = SUPPORTED_COA_LOCALES.filter((coaLocale) => coaLocale !== DEFAULT_COA_LOCALE);

const extractPrice = (priceStr: string): number => {
  const match = priceStr?.match(/[\d,]+(?:\.\d+)?/);
  return match ? parseFloat(match[0].replace(',', '')) : 99;
};

const productPrice = product.data.price ?? extractPrice(product.data.price_range);
const reviews = product.data.reviews ?? [];
const averageRating = reviews.length > 0
  ? reviews.reduce((sum: number, review: { rating: number }) => sum + review.rating, 0) / reviews.length
  : null;
const reviewObjects = reviews.length > 0
  ? reviews.map((review) => ({
      '@type': 'Review',
      author: { '@type': 'Person', name: review.author },
      datePublished: review.date,
      name: review.title,
      reviewBody: review.content,
      reviewRating: {
        '@type': 'Rating',
        ratingValue: String(review.rating),
        bestRating: '5',
        worstRating: '1',
      },
    }))
  : [{
      '@type': 'Review',
      author: { '@type': 'Organization', name: 'Peptide Shop' },
      datePublished: new Date().toISOString().slice(0, 10),
      name: `Peptide Shop review of ${cleanTitle}`,
      reviewBody: `This product page documents the ${cleanTitle} research-use peptide, including availability, shipping and COA support for laboratory research orders.`,
      reviewRating: {
        '@type': 'Rating',
        ratingValue: '5',
        bestRating: '5',
        worstRating: '1',
      },
    }];
const productReview = reviewObjects.length === 1 ? reviewObjects[0] : reviewObjects;
const aggregateRating = {
  '@type': 'AggregateRating',
  ratingValue: (averageRating ?? 5).toFixed(1),
  reviewCount: reviews.length > 0 ? reviews.length : 1,
  bestRating: '5',
  worstRating: '1',
};
const entityMap = entities as Record<string, { sameAs?: string[]; cas?: string | null; molecularFormula?: string | null; pubchem?: string | null; wikidata?: string | null }>;
const productEntity = entityMap[currentSlug];
const additionalProperties = [
  product.data.cas && { '@type': 'PropertyValue', name: 'CAS Number', value: product.data.cas },
  product.data.molecular_weight && { '@type': 'PropertyValue', name: 'Molecular weight', value: product.data.molecular_weight },
  product.data.purity && { '@type': 'PropertyValue', name: 'Purity', value: product.data.purity },
  productEntity?.molecularFormula && { '@type': 'PropertyValue', name: 'Molecular formula', value: productEntity.molecularFormula },
].filter(Boolean);

const relatedProducts = allProductsForLookup
  .filter((candidate) => candidate.id !== product.id && candidate.data.researchArea === product.data.researchArea)
  .slice(0, 4);

const priceValidUntil = new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  inLanguage: inLanguage(locale),
  name: cleanTitle,
  description: localizedProduct.meta.description,
  image: [productImageUrl],
  sku: product.data.id,
  mpn: product.data.id,
  brand: 'Peptide Shop',
  category: researchAreaName ?? product.data.category,
  ...(productEntity?.sameAs?.length ? { sameAs: productEntity.sameAs } : {}),
  ...(additionalProperties.length ? { additionalProperty: additionalProperties } : {}),
  offers: {
    '@type': 'Offer',
    url: productUrl,
    priceCurrency: 'EUR',
    price: productPrice.toFixed(2),
    priceValidUntil,
    availability: 'https://schema.org/InStock',
    itemCondition: 'https://schema.org/NewCondition',
    seller: {
      '@type': 'Organization',
      name: 'Peptide Shop',
    },
    hasMerchantReturnPolicy: {
      '@type': 'MerchantReturnPolicy',
      applicableCountry: ['DE', 'NL', 'FR', 'IT', 'ES', 'AT', 'BE', 'PL', 'SE', 'DK', 'FI', 'PT'],
      returnPolicyCategory: 'https://schema.org/MerchantReturnFiniteReturnWindow',
      merchantReturnDays: 14,
      returnMethod: 'https://schema.org/ReturnByMail',
      returnFees: 'https://schema.org/FreeReturn',
    },
    shippingDetails: {
      '@type': 'OfferShippingDetails',
      shippingDestination: {
        '@type': 'DefinedRegion',
        addressCountry: ['DE', 'NL', 'FR', 'IT', 'ES', 'AT', 'BE', 'PL', 'SE', 'DK', 'FI', 'PT'],
      },
      shippingRate: {
        '@type': 'MonetaryAmount',
        value: '9.90',
        currency: 'EUR',
      },
      deliveryTime: {
        '@type': 'ShippingDeliveryTime',
        handlingTime: {
          '@type': 'QuantitativeValue',
          minValue: 0,
          maxValue: 1,
          unitCode: 'DAY',
        },
        transitTime: {
          '@type': 'QuantitativeValue',
          minValue: 1,
          maxValue: 5,
          unitCode: 'DAY',
        },
      },
    },
  },
  review: productReview,
  aggregateRating,
};

const faqSchema = localizedProduct.faqs.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
    inLanguage: inLanguage(locale),
      mainEntity: localizedProduct.faqs.map((faq: { question: string; answer: string }) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer,
        },
      })),
    }
  : null;

const breadcrumbs = [
  { name: t('common.home'), url: href('/') },
  { name: t('productPage.catalogue'), url: href('/catalog/') },
  ...(researchArea && researchAreaName ? [{ name: researchAreaName, url: href(`/catalog/${researchArea.slug}/`) }] : []),
  { name: cleanTitle, url: href(`/peptides/${currentSlug}/`) },
];
---

<Layout
  title={localizedProduct.meta.title}
  description={localizedProduct.meta.description}
  image={productImage}
  breadcrumbs={breadcrumbs}
  availableLocales={availableLocales}
>
  <JsonLd schema={faqSchema ? [productSchema, faqSchema] : productSchema} />

  <section class="product-page section">
    <div class="container">
      <Breadcrumb items={[
        { name: t('common.home'), url: href('/') },
        { name: t('productPage.catalogue'), url: href('/catalog/') },
        ...(researchArea && researchAreaName ? [{ name: researchAreaName, url: href(`/catalog/${researchArea.slug}/`) }] : []),
        { name: cleanTitle },
      ]} />

      <RUOBanner
        heading={t('productPage.ruoHeading')}
        detail={t('productPage.ruoDetail')}
      />

      <div class="product-page-layout">
        <aside class="product-page-sidebar" aria-label={t('productPage.browseCatalogue')}>
          <ShopSidebar selectedArea={researchArea?.slug} />
        </aside>

        <div class="product-page-main">
      <div class="product-grid-layout">
        <div class="product-media card">
          <img src={productImage} alt={t('productPage.imageAlt', { product: cleanTitle })} width="720" height="720" decoding="async" fetchpriority="high" />
        </div>

        <div class="product-summary">
          <span class="eyebrow">{researchAreaName ?? product.data.category.replace(/-/g, ' ')}</span>
          <h1>{cleanTitle}</h1>
          <p class="lead">{localizedProduct.shortDescription}</p>

          <div class="product-badges" aria-label={t('productPage.qualityBadges')}>
            <span class="badge badge-success">{product.data.purity}</span>
            <span class="badge">{t('productPage.coaSupported')}</span>
            <span class="badge badge-warning">RUO</span>
          </div>

          <dl class="spec-list">
            {product.data.cas && <><dt>CAS</dt><dd>{product.data.cas}</dd></>}
            {product.data.molecular_weight && <><dt>{t('productPage.molecularWeight')}</dt><dd>{product.data.molecular_weight}</dd></>}
            <dt>{t('productPage.storage')}</dt><dd>{localizedProduct.storage}</dd>
            <dt>{t('productPage.packageSizes')}</dt><dd>{product.data.package_sizes.join(', ')}</dd>
          </dl>

          <div class="hub-links">
            {researchArea && <a class="chip" href={href(`/catalog/${researchArea.slug}/`)}>{t('productPage.browseArea', { area: researchAreaName ?? researchArea.name })}</a>}
            {productUseCases.map((useCase) => useCase && (
              <a class="chip" href={href(`/use-case/${useCase.slug}/`)}>{useCase.name}</a>
            ))}
          </div>
        </div>

        <aside class="buy-box card" aria-label={t('productPage.purchaseOptions')}>
          <h2>{t('productPage.selectOptions')}</h2>
          <ProductOptions
            client:load
            id={product.data.id}
            title={localizedProduct.title}
            basePrice={productPrice}
            packageSizes={product.data.package_sizes}
            moq={product.data.moq}
            image={productImage}
            category={product.data.category}
            labels={{
              price: t('productOptions.price'),
              perVial: t('productOptions.perVial'),
              defaultPackage: t('productOptions.defaultPackage'),
              quantity: t('productOptions.quantity'),
              selectQuantity: t('productOptions.selectQuantity'),
              decreaseQuantity: t('productOptions.decreaseQuantity'),
              increaseQuantity: t('productOptions.increaseQuantity'),
              orderSummary: t('productOptions.orderSummary'),
              subtotal: t('productOptions.subtotal'),
              delivery: t('productOptions.delivery'),
              free: t('productOptions.free'),
              calculatedAtCheckout: t('productOptions.calculatedAtCheckout'),
              addToCart: t('cartActions.addToCart'),
              addedToCart: t('cartActions.addedToCart'),
              minimumNote: t('productOptions.minimumNote'),
              ruoNote: t('productOptions.ruoNote'),
            }}
          />
          <div class="buy-box__links">
            <a href={href('/coa-policy/')} class="btn btn-secondary btn-block">{t('productPage.coaPolicyRequests')}</a>
            <a href={href('/shipping/')} class="btn btn-ghost btn-block">{t('productPage.shippingDetails')}</a>
          </div>
        </aside>
      </div>

      <nav class="tabs product-tabs" aria-label={t('productPage.detailSections')}>
        <a class="tab" href="#description">{t('productPage.description')}</a>
        <a class="tab" href="#data">{t('productPage.sequenceData')}</a>
        <a class="tab" href="#storage">{t('productPage.storage')}</a>
        <a class="tab" href="#coa">{t('productPage.coa')}</a>
        {localizedProduct.faqs.length > 0 && <a class="tab" href="#faqs">{t('productPage.faqs')}</a>}
      </nav>

      <div class="product-detail-layout">
        <article class="product-content card" id="description">
          <h2>{t('productPage.description')}</h2>
          <div class="prose-content">
            {locale === 'en' ? <Content /> : (OverrideContent ? <OverrideContent /> : <Fragment set:html={localizedProduct.bodyHtml} />)}
          </div>
        </article>

        <section class="card" id="data">
          <h2>{t('productPage.sequenceData')}</h2>
          <table class="table-clean">
            <tbody>
              <tr><th scope="row">{t('productPage.productId')}</th><td>{product.data.id}</td></tr>
              <tr><th scope="row">CAS</th><td>{product.data.cas ?? t('productPage.notAssigned')}</td></tr>
              <tr><th scope="row">{t('productPage.molecularWeight')}</th><td>{product.data.molecular_weight ?? t('productPage.notAssigned')}</td></tr>
              <tr><th scope="row">{t('productPage.purity')}</th><td>{product.data.purity}</td></tr>
              {product.data.sequence && <tr><th scope="row">{t('productPage.sequence')}</th><td class="text-mono">{product.data.sequence}</td></tr>}
            </tbody>
          </table>
        </section>

        <section class="card" id="storage">
          <h2>{t('productPage.storageHandling')}</h2>
          <p>{localizedProduct.storage}</p>
          <p>{t('productPage.storageHandlingBody')}</p>
        </section>

        <section class="card" id="coa">
          <h2>{t('productPage.certificate')}</h2>
          <p>{t('productPage.coaBody')}</p>
          <div class="coa-actions">
            <a class="btn btn-primary" href={`/api/coa/${currentSlug}.pdf`} download>
              {t('productPage.downloadCoa')}
            </a>
            <a class="btn btn-secondary" href={`/coa/${currentSlug}.html`} target="_blank" rel="noopener">
              {t('productPage.previewHtml')}
            </a>
            <a class="btn btn-ghost" href={href('/coa-policy/')}>{t('productPage.coaPolicy')}</a>
          </div>
          <details class="coa-langs">
            <summary>{t('productPage.otherLanguages')}</summary>
            <ul>
              {alternateCoaLocales.map((coaLocale) => (
                <li><a href={`/api/coa/${currentSlug}.pdf?lang=${coaLocale}`} download>{localeMeta[coaLocale].name} (PDF)</a> · <a href={`/coa/${currentSlug}.${coaLocale}.html`} target="_blank" rel="noopener">HTML</a></li>
              ))}
            </ul>
          </details>
        </section>

        {localizedProduct.faqs.length > 0 && (
          <section class="card" id="faqs">
            <ProductFAQs productName={cleanTitle} faqs={localizedProduct.faqs} heading={t('productPage.faqs')} />
          </section>
        )}
      </div>

      {relatedProducts.length > 0 && (
        <section class="section related-section" aria-labelledby="related-title">
          <span class="eyebrow">{t('productPage.relatedEyebrow')}</span>
          <h2 id="related-title">{t('productPage.relatedTitle', { area: researchAreaName ?? t('productPage.relatedFallbackArea') })}</h2>
          <div class="grid grid-4" style="margin-top: var(--space-8);">
            {relatedProducts.map((related) => (
              <ProductCard product={toCardProduct(related, locale)} />
            ))}
          </div>
        </section>
      )}
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .product-page { padding-top: var(--space-10); }
  .product-page-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: var(--space-8);
    align-items: start;
    margin-top: var(--space-6);
  }
  .product-page-sidebar {
    position: sticky;
    top: 88px;
  }
  .product-page-main { min-width: 0; }
  .product-grid-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr) minmax(320px, 0.8fr);
    gap: var(--space-8);
    align-items: start;
    margin-top: 0;
  }
  .product-media { padding: var(--space-6); background: var(--color-surface-2); }
  .product-media img { width: 100%; aspect-ratio: 1; object-fit: contain; }
  .product-summary h1 { margin-bottom: var(--space-4); }
  .product-badges,
  .hub-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-5);
  }
  .spec-list {
    display: grid;
    grid-template-columns: max-content minmax(0, 1fr);
    gap: var(--space-2) var(--space-4);
    margin-top: var(--space-6);
    font-size: var(--text-sm);
  }
  .spec-list dt { color: var(--color-ink-3); font-weight: 500; }
  .spec-list dd { margin: 0; color: var(--color-ink); font-weight: 600; }
  .buy-box { position: sticky; top: 96px; gap: var(--space-4); }
  .buy-box h2 { font-size: var(--text-xl); }
  .buy-box__links { display: grid; gap: var(--space-2); margin-top: var(--space-4); }
  .product-tabs { margin-top: var(--space-12); }
  .product-tabs a { text-decoration: none; }
  .product-detail-layout {
    display: grid;
    gap: var(--space-6);
    margin-top: var(--space-6);
  }
  .product-content { gap: var(--space-4); }
  .prose-content :global(h2),
  .prose-content :global(h3) { margin-top: var(--space-6); }
  .prose-content :global(p),
  .product-detail-layout p { color: var(--color-ink-2); }
  .related-section { padding-bottom: 0; }
  .coa-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }
  .coa-langs { margin-top: var(--space-4); font-size: var(--text-sm); color: var(--color-ink-2); }
  .coa-langs summary { cursor: pointer; color: var(--color-primary); font-weight: 600; }
  .coa-langs ul { margin: var(--space-3) 0 0; padding-left: var(--space-5); display: grid; gap: var(--space-2); }
  .coa-langs a { color: var(--color-primary); text-decoration: none; }
  .coa-langs a:hover { text-decoration: underline; }
  @media (max-width: 1100px) {
    .product-page-layout { grid-template-columns: 1fr; }
    .product-page-sidebar { position: static; order: 2; }
    .product-page-main { order: 1; }
    .product-grid-layout { grid-template-columns: 1fr 1fr; }
    .buy-box { grid-column: 1 / -1; position: static; }
  }
  @media (max-width: 768px) {
    .product-grid-layout { grid-template-columns: 1fr; }
    .spec-list { grid-template-columns: 1fr; }
  }
</style>
