---
import Layout from '../layouts/Layout.astro';
import PageHeading from '../components/PageHeading.astro';
import RelatedLinkList from '../components/RelatedLinkList.astro';
import { getLocaleFromPathname, localizePath } from '../i18n/config';
import { useTranslations } from '../i18n/ui';

const locale = (Astro.locals.locale ?? getLocaleFromPathname(Astro.url.pathname));
const t = useTranslations(locale);
const href = (path: string) => localizePath(path, locale);

const breadcrumbs = [
  { name: t('common.home'), url: href('/') },
  { name: t('nav.quality'), url: href('/quality/') },
];
---

<Layout
  title={t('quality.metaTitle')}
  description={t('quality.metaDescription')}
  breadcrumbs={breadcrumbs}
>
  <section class="section content-page">
    <div class="container">
      <PageHeading
        eyebrow={t('quality.eyebrow')}
        title={t('quality.title')}
        description={t('quality.description')}
      />

      <div class="content-layout">
        <article class="article-body">
<h2>{t('quality.analyticalFocus')}</h2>
          <figure class="editorial-figure">
            <img
              src="/images/lifestyle/research-use-only-label.webp"
              alt="Research-use-only labelled vials with manufacture and expiry dates"
              loading="lazy"
              width="800"
              height="480"
            />
          </figure>
          <div class="learning-grid">
            <div class="learning-panel">
              <h3>{t('quality.hplcTitle')}</h3>
              <p>{t('quality.hplcBody')}</p>
            </div>
            <div class="learning-panel">
              <h3>{t('quality.massTitle')}</h3>
              <p>{t('quality.massBody')}</p>
            </div>
            <div class="learning-panel">
              <h3>{t('quality.traceTitle')}</h3>
              <p>{t('quality.traceBody')}</p>
            </div>
            <div class="learning-panel">
              <h3>{t('quality.storageTitle')}</h3>
              <p>{t('quality.storageBody')}</p>
            </div>
          </div>

          <h2>{t('quality.certificateTitle')}</h2>
          <p>{t('quality.certificateBody')}</p>

          <h2>{t('quality.handlingTitle')}</h2>
          <p>{t('quality.handlingBody')}</p>
        </article>

        <aside class="content-sidebar" aria-label={t('quality.relatedInfo')}>
<div class="card">
            <h2>{t('quality.resourcesTitle')}</h2>
            <RelatedLinkList items={[
              { url: href('/coa-policy/'), title: t('quality.resourceCoaTitle'), subtitle: t('quality.resourceCoaSubtitle') },
              { url: href('/blog/understanding-peptide-purity-hplc-reports/'), title: t('quality.resourceHplcTitle'), subtitle: t('quality.resourceHplcSubtitle') },
              { url: href('/blog/peptide-storage-handling-best-practices/'), title: t('quality.resourceStorageTitle'), subtitle: t('quality.resourceStorageSubtitle') },
            ]} />
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<style>
  .editorial-figure {
    margin: 0 0 var(--space-6, 1.5rem);
    border-radius: var(--radius-xl, 1rem);
    overflow: hidden;
    border: 1px solid var(--color-border, rgba(0, 0, 0, 0.08));
    box-shadow: var(--shadow-soft-3, 0 8px 32px rgba(0, 0, 0, 0.06));
    aspect-ratio: 16 / 9;
  }
  .editorial-figure img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
