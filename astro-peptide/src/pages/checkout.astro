---
import Layout from '../layouts/Layout.astro';
import CheckoutComponent from '../components/Checkout';
import Breadcrumb from '../components/Breadcrumb.astro';
import PageHeading from '../components/PageHeading.astro';
import { getLocaleFromPathname, localizePath } from '../i18n/config';
import { useTranslations } from '../i18n/ui';

const locale = (Astro.locals.locale ?? getLocaleFromPathname(Astro.url.pathname));
const t = useTranslations(locale);
const href = (path: string) => localizePath(path, locale);
const checkoutLabelKeys = [
  'account', 'shipping', 'payment', 'review', 'summary', 'subtotal', 'delivery', 'free', 'total', 'bitcoinDiscount',
  'ruoRequired', 'ruoRequiredBody', 'emptyCart', 'minimumRequired', 'addProducts', 'minimumBody', 'browseCatalogue',
  'orderReceived', 'completeBitcoin', 'orderConfirmed', 'orderId', 'sendExactly', 'to', 'copyAddress', 'bankInstructions',
  'orderTotal', 'viewOrders', 'continueShopping', 'chooseContinue', 'guestCheckout', 'signIn', 'createAccount',
  'continueGuest', 'firstName', 'lastName', 'email', 'password', 'confirmPassword', 'pleaseWait', 'google', 'facebook',
  'passwordsMismatch', 'passwordLength', 'account_exists', 'invalid_credentials', 'shippingDetails', 'phone', 'address', 'city', 'county', 'postcode',
  'deliveryMethod', 'standardDelivery', 'standardTime', 'expressDelivery', 'expressTime', 'continuePayment',
  'selectPayment', 'bankTransfer', 'bankTransferHelp', 'bitcoin', 'bitcoinHelp', 'reviewOrder', 'back', 'confirmOrder',
  'bitcoinInvoice', 'bitcoinInvoiceError', 'researchUseOnly', 'reviewRuo', 'placingOrder', 'placeOrder',
] as const;
const checkoutLabels = Object.fromEntries(checkoutLabelKeys.map((key) => [key, t(`checkout.${key}`)]));
---

<Layout title={t('checkoutPage.metaTitle')} description={t('checkoutPage.metaDescription')} noindex={true}>
  <section class="commerce-page section">
    <div class="container">
      <Breadcrumb items={[
        { name: t('common.home'), url: href('/') },
        { name: t('cart.cart'), url: href('/cart/') },
        { name: t('cart.checkout') },
      ]} />

      <PageHeading
        eyebrow={t('checkoutPage.eyebrow')}
        title={t('checkoutPage.title')}
        description={t('checkoutPage.description')}
      />

      <CheckoutComponent
        labels={checkoutLabels}
        paths={{ shop: href('/shop/'), dashboard: href('/account/dashboard/') }}
        locale={locale}
        client:only="react"
      />
    </div>
  </section>
</Layout>
