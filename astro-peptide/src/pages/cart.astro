---
import Layout from '../layouts/Layout.astro';
import ShoppingCart from '../components/ShoppingCart';
import Breadcrumb from '../components/Breadcrumb.astro';
import PageHeading from '../components/PageHeading.astro';
import { getLocaleFromPathname, localizePath } from '../i18n/config';
import { useTranslations } from '../i18n/ui';

const locale = (Astro.locals.locale ?? getLocaleFromPathname(Astro.url.pathname));
const t = useTranslations(locale);
const href = (path: string) => localizePath(path, locale);
---

<Layout title={t('cartPage.metaTitle')} description={t('cartPage.metaDescription')} noindex={true}>
  <section class="commerce-page section">
    <div class="container">
      <Breadcrumb items={[{ name: t('common.home'), url: href('/') }, { name: t('cart.cart') }]} />

      <PageHeading
        eyebrow={t('cartPage.eyebrow')}
        title={t('cartPage.title')}
        description={t('cartPage.description')}
      />

      <ShoppingCart
        labels={{
          emptyTitle: t('cart.emptyTitle'),
          emptyPageBody: t('cart.emptyPageBody'),
          browseCatalogue: t('cart.browseCatalogue'),
          checkoutReady: t('cart.checkoutReady'),
          itemSelected: t('cart.itemSelected'),
          itemsSelected: t('cart.itemsSelected'),
          freeDeliveryReached: t('cart.freeDeliveryReached'),
          addForFreeDelivery: t('cart.addForFreeDelivery'),
          ruoLine: t('cart.ruoLine'),
          quantityFor: t('cart.quantityFor'),
          decreaseQuantity: t('productOptions.decreaseQuantity'),
          increaseQuantity: t('productOptions.increaseQuantity'),
          remove: t('cart.remove'),
          each: t('cart.each'),
          orderSummary: t('productOptions.orderSummary'),
          subtotal: t('productOptions.subtotal'),
          delivery: t('productOptions.delivery'),
          free: t('productOptions.free'),
          total: t('checkout.total'),
          ruoHeading: t('cart.ruoHeading'),
          ruoBody: t('cart.ruoBody'),
          minimumRequired: t('cart.minimumRequired'),
          proceedCheckout: t('cart.proceedCheckout'),
          minimumOrder: t('cart.minimumOrder'),
          continueShopping: t('cart.continueShopping'),
        }}
        paths={{ shop: href('/shop/'), checkout: href('/checkout/') }}
        client:only="react"
      />
    </div>
  </section>
</Layout>
