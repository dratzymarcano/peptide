---
// Header — DESIGN_SPEC §5.1
// Mega-menu by research area, accessible, no Bootstrap, no jQuery.
import CartIcon from './CartIcon';
import CartModal from './CartModal';
import CartNotification from './CartNotification';
import SearchBar from './SearchBar';
import { researchAreas, useCases } from '../data/taxonomy';
import { defaultLocale, getLocaleFromPathname, localizePath } from '../i18n/config';
import { useTranslations } from '../i18n/ui';

const halfA = researchAreas.slice(0, 6);
const halfB = researchAreas.slice(6, 12);
const locale = (Astro.locals.locale ?? getLocaleFromPathname(Astro.url.pathname));
const t = useTranslations(locale);
const href = (path: string) => localizePath(path, locale);
const localePrefix = locale === defaultLocale ? '' : `/${locale}`;
---

<div class="topbar">
  <div class="container topbar__inner">
    <span class="topbar__item"><strong>{t('nav.researchUseOnlyStrong')}</strong> {t('nav.researchUseOnlyShort')}</span>
    <span class="topbar__min-order" aria-label={t('nav.minOrderAria')}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
      <strong>{t('nav.minOrderTopbar')}</strong>
    </span>
    <div class="topbar__right">
      <a href="mailto:info@peptide-shop.net">info@peptide-shop.net</a>
      <span aria-hidden="true">·</span>
      <a href={href('/quality/')}>{t('nav.qualityTopbar')}</a>
    </div>
  </div>
</div>

<header class="site-header" id="site-header">
  <div class="container site-header__inner">
    <a href={href('/')} class="brand" aria-label={t('nav.homeLabel')}>
      <svg width="30" height="30" viewBox="0 0 32 32" aria-hidden="true" class="brand__mark">
        <rect x="1" y="1" width="30" height="30" rx="8" fill="var(--color-primary)" />
        <path d="M10 22 V10 h5 a4 4 0 0 1 0 8 h-5" stroke="#fff" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round" />
        <circle cx="22" cy="22" r="2" fill="#90E0EF" />
      </svg>
      <span class="brand__text">Peptide<span class="brand__accent">Shop</span></span>
    </a>

    <nav class="primary-nav" aria-label={t('common.primaryNavigation')}>
      <ul class="primary-nav__list">
        <li class="has-mega">
          <button
            class="primary-nav__link"
            type="button"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="mega-catalog"
            data-mega-toggle="catalog"
          >
            {t('nav.catalogue')}
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div id="mega-catalog" class="mega" role="region" aria-label={t('nav.catalogueRegion')} hidden>
            <div class="container mega__inner">
              <div class="mega__col">
                <span class="eyebrow">{t('nav.byResearchArea')}</span>
                <ul class="mega__list">
                  {halfA.map((a) => (
                    <li>
                      <a href={href(`/catalog/${a.slug}/`)}>
                        <strong>{a.name}</strong>
                        <span class="muted">{a.short}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="mega__col">
                <span class="eyebrow">&nbsp;</span>
                <ul class="mega__list">
                  {halfB.map((a) => (
                    <li>
                      <a href={href(`/catalog/${a.slug}/`)}>
                        <strong>{a.name}</strong>
                        <span class="muted">{a.short}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="mega__col mega__col--side">
                <span class="eyebrow">{t('nav.byUseCase')}</span>
                <ul class="mega__list mega__list--compact">
                  {useCases.map((u) => (
                    <li><a href={href(`/use-case/${u.slug}/`)}>{u.name}</a></li>
                  ))}
                </ul>
                <div class="mega__cta">
                  <a href={href('/catalog/')} class="btn btn-secondary btn-sm">{t('nav.browseFullCatalogue')}</a>
                </div>
              </div>
            </div>
          </div>
        </li>
        <li><a class="primary-nav__link" href={href('/shop/')}>{t('nav.shop')}</a></li>
        <li><a class="primary-nav__link" href={href('/quality/')}>{t('nav.quality')}</a></li>
        <li><a class="primary-nav__link" href={href('/blog/')}>{t('nav.insights')}</a></li>
        <li><a class="primary-nav__link" href={href('/about/')}>{t('nav.about')}</a></li>
        <li><a class="primary-nav__link" href={href('/contact/')}>{t('nav.contact')}</a></li>
      </ul>
    </nav>

    <div class="header-actions">
      <SearchBar
        labels={{
          openSearch: t('search.openSearch'),
          searchCatalogue: t('search.searchCatalogue'),
          search: t('search.search'),
          closeSearch: t('search.closeSearch'),
          close: t('common.closeMenu'),
          searching: t('search.searching'),
          noResults: t('search.noResults'),
        }}
        localePrefix={localePrefix}
        searchPath={href('/search/')}
        locale={locale}
        client:load
      />
      <CartIcon label={t('cart.openCart')} client:load />
      <button
        class="mobile-toggle"
        type="button"
        aria-label={t('common.openMenu')}
        aria-expanded="false"
        aria-controls="mobile-drawer"
        data-mobile-toggle
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="4" y1="6"  x2="20" y2="6" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="18" x2="20" y2="18" />
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile drawer -->
<div class="drawer-backdrop" data-drawer-backdrop></div>
<aside class="drawer" id="mobile-drawer" aria-label={t('common.mobileNavigation')} hidden>
  <div class="drawer-header">
    <strong>{t('common.menu')}</strong>
    <button class="btn btn-ghost btn-sm" type="button" aria-label={t('common.closeMenu')} data-drawer-close>✕</button>
  </div>
  <div class="drawer-body">
    <details class="m-acc">
      <summary>{t('nav.catalogue')}</summary>
      <ul class="m-list">
        <li><a href={href('/catalog/')}><strong>{t('nav.allResearchAreas')}</strong></a></li>
        {researchAreas.map((a) => (
          <li><a href={href(`/catalog/${a.slug}/`)}>{a.name}</a></li>
        ))}
      </ul>
    </details>
    <details class="m-acc">
      <summary>{t('nav.useCases')}</summary>
      <ul class="m-list">
        {useCases.map((u) => (
          <li><a href={href(`/use-case/${u.slug}/`)}>{u.name}</a></li>
        ))}
      </ul>
    </details>
    <ul class="m-list" style="margin-top: var(--space-4);">
      <li><a href={href('/shop/')}>{t('nav.shop')}</a></li>
      <li><a href={href('/quality/')}>{t('nav.quality')}</a></li>
      <li><a href={href('/blog/')}>{t('nav.insights')}</a></li>
      <li><a href={href('/about/')}>{t('nav.about')}</a></li>
      <li><a href={href('/contact/')}>{t('nav.contact')}</a></li>
    </ul>
  </div>
</aside>

<CartModal
  labels={{
    closeCart: t('cart.closeCart'),
    shoppingCart: t('cart.shoppingCart'),
    cart: t('cart.cart'),
    item: t('cart.item'),
    items: t('cart.items'),
    emptyTitle: t('cart.emptyTitle'),
    emptyModalBody: t('cart.emptyModalBody'),
    browseCatalogue: t('cart.browseCatalogue'),
    quantityFor: t('cart.quantityFor'),
    decreaseQuantity: t('productOptions.decreaseQuantity'),
    increaseQuantity: t('productOptions.increaseQuantity'),
    remove: t('cart.remove'),
    subtotal: t('productOptions.subtotal'),
    minimumOrder: t('cart.minimumOrder'),
    addToContinue: t('cart.addToContinue'),
    checkout: t('cart.checkout'),
    minimum: t('cart.minimum'),
    viewCart: t('cart.viewCart'),
  }}
  paths={{ catalogue: href('/catalog/'), checkout: href('/checkout/'), cart: href('/cart/') }}
  client:load
/>
<CartNotification
  labels={{
    cartUpdate: t('cart.cartUpdate'),
    addedToCart: t('cart.addedToCart'),
    closeNotification: t('cart.closeNotification'),
    close: t('common.closeMenu'),
    viewCart: t('cart.viewCart'),
    checkout: t('cart.checkout'),
  }}
  paths={{ checkout: href('/checkout/') }}
  client:load
/>

<style>
  .topbar {
    background: var(--color-ink);
    color: #E2E8F0;
    font-size: 12px;
    padding: 6px 0;
  }
  .topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .topbar__right { display: inline-flex; gap: var(--space-2); align-items: center; }
  .topbar__min-order {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 2px 10px;
    background: rgba(144, 224, 239, 0.18);
    color: #E0FBFC;
    border: 1px solid rgba(144, 224, 239, 0.45);
    border-radius: 999px;
    font-size: 12px;
    line-height: 1.3;
    white-space: nowrap;
  }
  .topbar__min-order strong { color: #fff; font-weight: 700; }
  .topbar a { color: #E2E8F0; text-decoration: underline; text-decoration-color: rgb(255 255 255 / 0.25); }
  .topbar a:hover { color: #fff; }
  @media (max-width: 600px) {
    .topbar__inner { row-gap: 4px; }
    .topbar__min-order { order: 2; }
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 1px solid var(--color-border);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    height: 64px;
  }

  .brand { display: inline-flex; align-items: center; gap: 10px; text-decoration: none; }
  .brand__mark { display: block; }
  .brand__text { font-family: var(--font-display); font-weight: 700; color: var(--color-ink); font-size: 19px; letter-spacing: -0.02em; }
  .brand__accent { color: var(--color-primary); }

  .primary-nav { display: none; flex: 1; }
  .primary-nav__list { display: flex; gap: var(--space-1); list-style: none; margin: 0; padding: 0; }
  .primary-nav__link {
    position: relative;
    display: inline-flex; align-items: center; gap: 4px;
    height: 64px; padding: 0 var(--space-3);
    background: transparent; border: 0;
    color: var(--color-ink-2); font-weight: 600; font-size: 14px;
    cursor: pointer; text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out-soft);
  }
  .primary-nav__link::after {
    content: "";
    position: absolute; left: var(--space-3); right: var(--space-3); bottom: 14px;
    height: 2px; background: var(--color-primary); border-radius: 2px;
    transform: scaleX(0); transform-origin: left center;
    transition: transform var(--dur-base) var(--ease-out-soft);
  }
  .primary-nav__link:hover { color: var(--color-primary); }
  .primary-nav__link:hover::after,
  .primary-nav__link[aria-expanded="true"]::after { transform: scaleX(1); }
  .has-mega { position: relative; }
  .has-mega .primary-nav__link[aria-expanded="true"] { color: var(--color-primary); }

  .header-actions { display: inline-flex; align-items: center; gap: var(--space-2); margin-left: auto; }
  .mobile-toggle {
    display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px;
    background: transparent; border: 1px solid var(--color-border);
    border-radius: var(--radius-sm); color: var(--color-ink);
  }
  .mobile-toggle:hover { background: var(--color-surface-2); }

  /* Mega panel */
  .mega {
    position: absolute;
    left: 0; right: auto;
    top: 100%;
    width: min(960px, calc(100vw - var(--container-pad) * 2));
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-2);
    padding: var(--space-6);
    margin-top: 4px;
  }
  .mega[hidden] { display: none; }
  .mega__inner {
    display: grid;
    grid-template-columns: 1fr 1fr 0.8fr;
    gap: var(--space-8);
    padding: 0;
    max-width: none;
  }
  .mega__list { list-style: none; padding: 0; margin: var(--space-2) 0 0; display: grid; gap: var(--space-1); }
  .mega__list a {
    display: block; padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm); text-decoration: none;
  }
  .mega__list a:hover { background: var(--color-primary-50); }
  .mega__list strong { display: block; color: var(--color-ink); font-size: 14px; }
  .mega__list .muted { color: var(--color-ink-3); font-size: 12px; }
  .mega__list--compact a { padding: 6px var(--space-3); color: var(--color-ink-2); font-size: 14px; }
  .mega__col--side { border-left: 1px solid var(--color-border); padding-left: var(--space-6); }
  .mega__cta { margin-top: var(--space-4); }

  /* Mobile-first */
  @media (max-width: 1023px) {
    .primary-nav { display: none !important; }
  }
  @media (min-width: 1024px) {
    .primary-nav { display: flex; }
    .mobile-toggle { display: none; }
  }

  /* Mobile drawer overrides (drawer base in design-system.css) */
  .m-acc { border-bottom: 1px solid var(--color-border); padding: var(--space-3) 0; }
  .m-acc summary {
    cursor: pointer; font-weight: 600; color: var(--color-ink);
    list-style: none; display: flex; align-items: center; justify-content: space-between;
  }
  .m-acc summary::-webkit-details-marker { display: none; }
  .m-acc summary::after { content: '+'; font-size: 18px; color: var(--color-ink-3); }
  .m-acc[open] summary::after { content: '-'; }
  .m-list { list-style: none; padding: var(--space-2) 0 0; margin: 0; display: grid; gap: 4px; }
  .m-list a { display: block; padding: var(--space-2) var(--space-3); color: var(--color-ink-2); border-radius: var(--radius-sm); text-decoration: none; }
  .m-list a:hover { background: var(--color-primary-50); color: var(--color-primary); }
</style>

<script>
  // Mega-menu accessibility (Esc, focus trap-light, click-outside)
  document.querySelectorAll<HTMLButtonElement>('[data-mega-toggle]').forEach((btn) => {
    const id = btn.getAttribute('aria-controls');
    if (!id) return;
    const panel = document.getElementById(id);
    if (!panel) return;

    const close = () => {
      btn.setAttribute('aria-expanded', 'false');
      panel.hidden = true;
    };
    const open = () => {
      btn.setAttribute('aria-expanded', 'true');
      panel.hidden = false;
    };

    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      expanded ? close() : open();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') {
        close();
        btn.focus();
      }
    });
    document.addEventListener('click', (e) => {
      const t = e.target as Node;
      if (btn.getAttribute('aria-expanded') !== 'true') return;
      if (!panel.contains(t) && !btn.contains(t)) close();
    });
  });

  // Mobile drawer
  const toggleBtn = document.querySelector<HTMLButtonElement>('[data-mobile-toggle]');
  const drawer = document.getElementById('mobile-drawer');
  const backdrop = document.querySelector<HTMLElement>('[data-drawer-backdrop]');
  const closeBtn = document.querySelector<HTMLButtonElement>('[data-drawer-close]');
  const setOpen = (open: boolean) => {
    if (!drawer || !backdrop || !toggleBtn) return;
    drawer.hidden = !open;
    drawer.classList.toggle('is-open', open);
    backdrop.classList.toggle('is-open', open);
    toggleBtn.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  };
  toggleBtn?.addEventListener('click', () => setOpen(drawer?.hidden === true));
  closeBtn?.addEventListener('click', () => setOpen(false));
  backdrop?.addEventListener('click', () => setOpen(false));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setOpen(false); });
</script>
