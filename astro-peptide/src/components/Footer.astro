---
// Footer — DESIGN_SPEC §5.4
// 6 columns, RUO disclaimer pinned, no Bootstrap, no jQuery.
import { researchAreas, useCases } from '../data/taxonomy';
import { getLocaleFromPathname, localizePath } from '../i18n/config';
import { useTranslations } from '../i18n/ui';

const featured = researchAreas.slice(0, 6);
const year = new Date().getFullYear();
const locale = (Astro.locals.locale ?? getLocaleFromPathname(Astro.url.pathname));
const t = useTranslations(locale);
const href = (path: string) => localizePath(path, locale);
---

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col footer-col--brand">
        <a href={href('/')} class="footer-brand" aria-label={t('nav.homeLabel')}>
          <svg width="28" height="28" viewBox="0 0 32 32" aria-hidden="true">
            <rect x="1" y="1" width="30" height="30" rx="8" fill="var(--color-primary)" />
            <path d="M10 22 V10 h5 a4 4 0 0 1 0 8 h-5" stroke="#fff" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            <circle cx="22" cy="22" r="2" fill="#90E0EF" />
          </svg>
          <span><strong>Peptide</strong>Shop</span>
        </a>
        <p class="footer-tagline">
          {t('footer.tagline')}
        </p>
        <div class="trust-band" style="justify-content: flex-start; padding: var(--space-3); margin-top: var(--space-4);">
          <span class="item">{t('footer.trustHplc')}</span>
          <span class="item">{t('footer.trustCoa')}</span>
          <span class="item">{t('footer.trustDispatch')}</span>
        </div>
      </div>

      <div class="footer-col">
        <h4>{t('nav.catalogue')}</h4>
        <ul>
          <li><a href={href('/catalog/')}>{t('nav.allResearchAreas')}</a></li>
          {featured.map((a) => (
            <li><a href={href(`/catalog/${a.slug}/`)}>{a.name}</a></li>
          ))}
          <li><a href={href('/catalog/')}>{t('footer.viewAllAreas')}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>{t('nav.useCases')}</h4>
        <ul>
          {useCases.map((u) => (
            <li><a href={href(`/use-case/${u.slug}/`)}>{u.name}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h4>{t('footer.company')}</h4>
        <ul>
          <li><a href={href('/about/')}>{t('nav.about')}</a></li>
          <li><a href={href('/quality/')}>{t('footer.qualityCoaPolicy')}</a></li>
          <li><a href={href('/blog/')}>{t('nav.insights')}</a></li>
          <li><a href={href('/contact/')}>{t('nav.contact')}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>{t('footer.orderSupport')}</h4>
        <ul>
          <li><a href={href('/shipping/')}>{t('footer.shippingDelivery')}</a></li>
          <li><a href={href('/coa-policy/')}>{t('footer.coaPolicy')}</a></li>
          <li><a href={href('/faq/')}>{t('footer.faq')}</a></li>
          <li><a href={href('/contact/')}>{t('footer.contactSupport')}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>{t('footer.newsletter')}</h4>
        <p class="muted" style="font-size: 13px;">
          {t('footer.newsletterBody')}
        </p>
        <form class="newsletter" action={href('/api/newsletter')} method="post" novalidate>
          <label class="sr-only" for="footer-email">{t('footer.emailAddress')}</label>
          <input class="input" type="email" id="footer-email" name="email" required autocomplete="email" placeholder="you@laboratory.eu" />
          <button type="submit" class="btn btn-primary">{t('footer.subscribe')}</button>
        </form>
        <p class="muted" style="font-size: 11px; margin-top: var(--space-2);">
          {t('footer.privacyConsentStart')} <a href={href('/privacy/')}>{t('footer.privacyPolicy')}</a>.
        </p>
      </div>
    </div>

    <div class="ruo-banner" style="margin-top: var(--space-10);">
      <strong>{t('footer.ruoHeading')}</strong>
      <span>
        {t('footer.ruoBody')}
      </span>
    </div>

    <div class="footer-bottom">
      <p>{t('footer.copyright', { year })}</p>
      <ul class="footer-legal">
        <li><a href={href('/impressum/')}>{t('footer.impressum')}</a></li>
        <li><a href={href('/terms/')}>{t('footer.terms')}</a></li>
        <li><a href={href('/privacy/')}>{t('footer.privacy')}</a></li>
        <li><a href={href('/disclaimer/')}>{t('footer.disclaimer')}</a></li>
        <li><a href={href('/coa-policy/')}>{t('footer.coaPolicy')}</a></li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-surface-2);
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-16) var(--space-8);
    margin-top: var(--space-20);
  }
  .footer-grid {
    display: grid;
    gap: var(--space-8);
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1.4fr 1fr 1fr 1fr 1fr 1.2fr;
    }
  }
  .footer-col h4 {
    font-size: 13px;
    font-weight: 700;
    color: var(--color-ink);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-3);
  }
  .footer-col ul {
    list-style: none; padding: 0; margin: 0;
    display: grid; gap: 6px;
  }
  .footer-col a {
    color: var(--color-ink-2);
    font-size: 14px;
    text-decoration: none;
  }
  .footer-col a:hover { color: var(--color-primary); text-decoration: underline; }

  .footer-brand {
    display: inline-flex; align-items: center; gap: var(--space-2);
    text-decoration: none; color: var(--color-ink); font-size: 18px;
  }
  .footer-tagline {
    margin-top: var(--space-3);
    color: var(--color-ink-3);
    font-size: 14px;
    max-width: 38ch;
  }

  .newsletter {
    display: flex; gap: var(--space-2); margin-top: var(--space-2);
  }
  .newsletter .input { flex: 1; }

  .footer-bottom {
    margin-top: var(--space-10);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    display: flex; flex-wrap: wrap; gap: var(--space-4);
    justify-content: space-between; align-items: center;
    font-size: 13px; color: var(--color-ink-3);
  }
  .footer-bottom p { margin: 0; }
  .footer-legal { display: flex; gap: var(--space-4); list-style: none; padding: 0; margin: 0; }
  .footer-legal a { color: var(--color-ink-3); text-decoration: none; }
  .footer-legal a:hover { color: var(--color-primary); }

  .muted { color: var(--color-ink-3); }
</style>
