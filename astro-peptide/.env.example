# Peptide Shop Environment Variables

# Site Configuration
SITE_URL=https://peptide-kaufen.net

# BTCPay Server Configuration
# BTCPay Server is an open-source, self-hosted Bitcoin payment processor
# Documentation: https://docs.btcpayserver.org/
#
# Option 1: Self-hosted BTCPay Server
# - Deploy on your own server using Docker
# - Full control over your funds (no third party)
# - Free to use
#
# Option 2: Third-party hosting
# - Use services like Voltage, LunaNode, or others
# - Easier setup, monthly fee applies

BTCPAY_SERVER_URL=https://btcpay.peptide-kaufen.net
BTCPAY_STORE_ID=your_store_id_here
BTCPAY_API_KEY=your_api_key_here
BTCPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Bank Transfer Details (for reference in order emails)
BANK_NAME=Barclays Bank UK
BANK_ACCOUNT_NAME=Peptide Shop Ltd
BANK_SORT_CODE=20-00-00
BANK_ACCOUNT_NUMBER=12345678

# Email Configuration (Resend — https://resend.com)
# Set these via: npx wrangler secret put RESEND_API_KEY  etc.
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM=Peptide Shop <info@peptide-kaufen.net>
RESEND_TO=info@peptide-kaufen.net
CONTACT_TO=info@peptide-kaufen.net
